      "parameters": {
        "jsCode": "const text = $json.output || \"\";\nconst originalText = $json.original_message;\n\n// Escapar HTML\nlet escaped = text\n  .replace(/&/g, \"&amp;\")\n  .replace(/</g, \"&lt;\")\n  .replace(/>/g, \"&gt;\");\n\n// Reemplazo con validación\nescaped = escaped.replace(\n  /COMPROBANTE PAGADO A OTRO DESTINATARIO/gi,\n  () => {\n    let extra = \"\";\n    if (originalText) {\n      extra = `\n        <br>\n        <em style=\"color:#555;\">\n          Datos del mensaje original: ${originalText}\n        </em>\n      `;\n    }\n\n    return `\n      <strong style=\"color:#d32f2f;\">\n        COMPROBANTE PAGADO A OTRO DESTINATARIO\n      </strong>\n      ${extra}\n    `;\n  }\n);\n\n// Saltos de línea → <br>\nconst html = escaped.replace(/\\n/g, \"<br>\");\n\nreturn [{\n  json: {\n    ...$json,\n    output_html: `\n      <div style=\"font-family: Arial, sans-serif; line-height:1.6\">\n        ${html}\n      </div>\n    `\n  }\n}];\n"
